import numpy as np

class SphericalShellGrid:
    """
    PP–NF custom spherical radial grid.
    Pure logarithmic spacing.
    4096 shells spanning a 1 Gpc universe patch.
    """

    def __init__(self,
                 r_min=1e-3,          # smallest resolvable radius (kpc units)
                 r_max=1e6,           # 1 Gpc = 1e6 kpc
                 num_shells=4096):
        self.r_min = r_min
        self.r_max = r_max
        self.num_shells = num_shells

        # Logarithmic radial spacing
        self.r_edges = np.logspace(
            np.log10(r_min),
            np.log10(r_max),
            num_shells + 1
        )

        # Shell centers
        self.r_centers = 0.5 * (self.r_edges[:-1] + self.r_edges[1:])

        # Shell volumes (spherical shells)
        self.shell_volumes = (4.0 / 3.0) * np.pi * (
            self.r_edges[1:]**3 - self.r_edges[:-1]**3
        )

    # ------------------------------------------------------------------
    # Mapping PP particle positions → radial shell index
    # ------------------------------------------------------------------
    def map_positions_to_shells(self, positions):
        """
        positions: numpy array of shape (N, 3)
        returns: numpy array of shell indices (N,)
        """
        r = np.linalg.norm(positions, axis=1)
        indices = np.searchsorted(self.r_edges, r, side='right') - 1

        # Clamp out-of-range values
        indices = np.clip(indices, 0, self.num_shells - 1)
        return indices

    # ------------------------------------------------------------------
    # GPU-friendly export
    # ------------------------------------------------------------------
    def to_torch(self, device):
        """
        Export radial grid to PyTorch tensors on GPU.
        """
        import torch

        return {
            "r_edges": torch.tensor(self.r_edges, dtype=torch.float32, device=device),
            "r_centers": torch.tensor(self.r_centers, dtype=torch.float32, device=device),
            "shell_volumes": torch.tensor(self.shell_volumes, dtype=torch.float32, device=device)
        }

