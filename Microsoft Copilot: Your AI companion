import numpy as np

class NFPPExchange:
    """
    NF expansion ↔ PP contraction in the differential-only regime.

    - At symmetry: no change.
    - As PP density deviates from symmetry, NF expands into underdense regions,
      PP contracts around them, and PP rigidity increases with contraction.
    """

    def __init__(self,
                 nf_base_stiffness=1.0,
                 pp_base_rigidity=1.0,
                 contraction_gain=1.0,
                 rigidity_gain=1.0):
        self.nf_base_stiffness = nf_base_stiffness
        self.pp_base_rigidity = pp_base_rigidity
        self.contraction_gain = contraction_gain
        self.rigidity_gain = rigidity_gain

    def step(self, pp_density, nf_volume, nf_stiffness, pp_rigidity):
        """
        pp_density:  array (cells,)   – PP density field
        nf_volume:   array (cells,)   – NF volume field
        nf_stiffness:array (cells,)   – NF stiffness field
        pp_rigidity: array (cells,)   – PP rigidity field

        Returns updated (nf_volume, nf_stiffness, pp_rigidity).
        """

        # Symmetry reference: mean PP density
        rho_sym = np.mean(pp_density)

        # Differential from symmetry (only the deviation matters)
        delta_rho = rho_sym - pp_density  # >0: underdense (gap), <0: overdense

        # NF expands only into underdense regions (gaps)
        nf_expansion = np.clip(delta_rho, a_min=0.0, a_max=None)

        # Scale expansion by base stiffness
        delta_nf_volume = self.contraction_gain * nf_expansion / (
            self.nf_base_stiffness + nf_stiffness
        )

        # PP contracts equally opposite, only where NF expands
        delta_pp_contraction = -delta_nf_volume  # opposite sign, same magnitude

        # Update NF volume
        nf_volume_new = nf_volume + delta_nf_volume

        # NF stiffness increases where PP contraction is high (more resistance)
        nf_stiffness_new = nf_stiffness + self.rigidity_gain * np.abs(delta_pp_contraction)

        # PP rigidity increases with accumulated contraction (more locked-in)
        pp_rigidity_new = pp_rigidity + self.rigidity_gain * np.abs(delta_pp_contraction)

        return nf_volume_new, nf_stiffness_new, pp_rigidity_new
Key properties baked in:

At symmetry (pp_density == rho_sym):
delta_rho = 0 → nf_expansion = 0 → no NF expansion, no PP contraction, no rigidity change.

Differential‑driven: only deviations from symmetry drive dynamics.

PP contracts normal from symmetry: contraction is proportional to how underdense a region is relative to the symmetric mean.

Rigidity grows with differential: both NF stiffness and PP rigidity increase where contraction is strongest.

